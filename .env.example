APP_NAME=ResearchWorkflowSystem
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=research-files

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_ADDRESS=noreply@research-system.local
EMAILS_FROM_NAME=Research System

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

LOG_LEVEL=INFO
LOG_FORMAT=json
